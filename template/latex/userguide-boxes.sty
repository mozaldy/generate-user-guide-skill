\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{userguide-boxes}[2026/04/30 v1.0 User Guide Boxes]

\RequirePackage{tcolorbox}
\RequirePackage{fontawesome5}
\tcbuselibrary{skins,breakable}

% Callout Boxes (Note / Tip / Warning / Danger / Info)
\newtcolorbox{ugNote}[1][Note]{%
  enhanced, breakable,
  colback=ugInfo!5, colframe=ugInfo,
  leftrule=4pt, rightrule=0.5pt, toprule=0.5pt, bottomrule=0.5pt,
  fonttitle=\bfseries\color{ugInfo},
  title={\faInfoCircle\hspace{6pt}#1},
  boxsep=4pt, left=6pt, right=6pt, top=4pt, bottom=4pt,
  arc=2pt
}

\newtcolorbox{ugTip}[1][Tip]{%
  enhanced, breakable,
  colback=ugSuccess!5, colframe=ugSuccess,
  leftrule=4pt, rightrule=0.5pt, toprule=0.5pt, bottomrule=0.5pt,
  fonttitle=\bfseries\color{ugSuccess},
  title={\faLightbulb\hspace{6pt}#1},
  boxsep=4pt, left=6pt, right=6pt, top=4pt, bottom=4pt,
  arc=2pt
}

\newtcolorbox{ugWarning}[1][Warning]{%
  enhanced, breakable,
  colback=ugWarning!5, colframe=ugWarning,
  leftrule=4pt, rightrule=0.5pt, toprule=0.5pt, bottomrule=0.5pt,
  fonttitle=\bfseries\color{ugWarning},
  title={\faExclamationTriangle\hspace{6pt}#1},
  boxsep=4pt, left=6pt, right=6pt, top=4pt, bottom=4pt,
