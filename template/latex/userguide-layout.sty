% ============================================================================
% userguide-layout.sty
% ============================================================================
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{userguide-layout}[2026/04/30 v1.0 User Guide Layout]

\RequirePackage{geometry}
\RequirePackage{fancyhdr}
\RequirePackage{hyperref}
\RequirePackage{graphicx}
\RequirePackage{float}

% Page Geometry
\geometry{
  a4paper,
  top=30mm,
  bottom=30mm,
  left=28mm,
  right=22mm,
  headheight=22pt
}

% Hyperref Setup
\hypersetup{
  colorlinks=true,
  linkcolor=ugPrimary,
  urlcolor=ugSecondary,
  citecolor=ugPrimary,
  bookmarksnumbered=true,
  bookmarksopen=true,
  bookmarksopenlevel=2,
  pdfstartview=FitH
}

% Header / Footer
\pagestyle{fancy}
\fancyhf{}
\renewcommand{\headrulewidth}{0.6pt}
\renewcommand{\headrule}{\hbox to\headwidth{\color{ugPrimary}\leaders\hrule height \headrulewidth\hfill}}
\renewcommand{\footrulewidth}{0.3pt}
\renewcommand{\footrule}{\hbox to\headwidth{\color{ugBorder}\leaders\hrule height \footrulewidth\hfill}}

\fancyhead[L]{\small\color{ugMutedText}\@ugAppName}
\fancyhead[R]{\small\color{ugMutedText}v\@ugDocVersion}
\fancyfoot[L]{\small\color{ugMutedText}\@ugCompany}
\fancyfoot[C]{\small\color{ugMutedText}Page \thepage}
\fancyfoot[R]{\small\color{ugMutedText}\@ugClassification}

\fancypagestyle{plain}{%
  \fancyhf{}
  \renewcommand{\headrulewidth}{0pt}
  \fancyfoot[C]{\small\color{ugMutedText}Page \thepage}
}

% Screenshot / Figure Command
\newcommand{\ugScreenshot}[3][0.85]{%
  % #1 = width (optional, default 0.85\textwidth)
  % #2 = image path
  % #3 = caption
  \begin{figure}[H]
    \centering
    \fcolorbox{ugBorder}{white}{%
      \includegraphics[width=#1\textwidth]{#2}%
    }
    \caption{#3}
  \end{figure}
}

\endinput
