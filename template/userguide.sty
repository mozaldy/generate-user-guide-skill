% ---------------------------------------------------------------------------
% Cover Page  (modern card-style layout inspired by enterprise templates)
% ---------------------------------------------------------------------------
% Helper: icon card used on cover
\newcommand{\@ugCoverCard}[3]{%
  % #1 = FA icon   #2 = label   #3 = value
  \begin{tikzpicture}[baseline=(lbl.base)]
    \node[fill=ugPrimary!12, rounded corners=6pt,
          minimum size=11mm, inner sep=0pt] (ico)
      {\color{ugPrimary}\large #1};
    \node[right=8pt of ico, anchor=north west] (lbl)
      {\small\bfseries\color{ugPrimary}#2};
    \node[right=8pt of ico, anchor=south west, yshift=1pt] (val)
      {\small\color{ugDarkText}#3};
  \end{tikzpicture}%
}

\newcommand{\ugMakeCover}{%
  \hypersetup{pageanchor=false}%  suppress duplicate page.1 dest from titlepage
  \begin{titlepage}
    \thispagestyle{empty}
    \begin{tikzpicture}[remember picture, overlay]
      % --- subtle gradient top-right splash ----------------------------------
      \fill[ugCoverLight, opacity=0.45]
        ([xshift=-70mm]current page.north east)
        .. controls +(-30mm,-50mm) and +(30mm,50mm) ..
        ([yshift=-90mm]current page.north east)
        -- (current page.north east) -- cycle;

      % --- decorative dot grid (right side) ----------------------------------
      \foreach \r in {0,...,7} {
        \foreach \c in {0,...,4} {
          \fill[ugDotColor, opacity=0.5]
            ([xshift={-12mm+\c*6mm}, yshift={-155mm-\r*6mm}]current page.north east)
            circle (0.7pt);
        }
      }

      % --- decorative hexagons (right side) ----------------------------------
      \def\hexpath##1##2##3{%
        \draw[ugPrimaryLight, line width=0.6pt, opacity=##3,
              rounded corners=1pt]
          ([xshift=##1, yshift=##2]current page.north east)
          ++(0:8mm) -- ++(60:8mm) -- ++(120:8mm)
          -- ++(180:8mm) -- ++(240:8mm) -- ++(300:8mm) -- cycle;
      }
      \hexpath{-50mm}{-55mm}{0.35}
      \hexpath{-30mm}{-75mm}{0.25}
      \hexpath{-65mm}{-85mm}{0.20}
      \hexpath{-15mm}{-100mm}{0.30}
      \hexpath{-45mm}{-110mm}{0.18}

      % --- Cover image (if provided) ----------------------------------------
      \ifx\@ugCoverImagePath\empty\else
        \node[anchor=north east, inner sep=0pt,
              opacity=0.92, rounded corners=4mm,
              clip] at ([xshift=-10mm, yshift=-35mm]current page.north east)
          {\includegraphics[width=75mm]{\@ugCoverImagePath}};
      \fi

      % --- bottom separator line ---------------------------------------------
      \draw[ugBorder, line width=0.4pt]
        ([yshift=42mm, xshift=15mm]current page.south west) --
        ([yshift=42mm, xshift=-15mm]current page.south east);

      % --- bottom purple accent strip ----------------------------------------
      \fill[ugPrimary] (current page.south west) rectangle
        ([yshift=3mm]current page.south east);
    \end{tikzpicture}

    % === TOP: Logo + Company name ==========================================
    \vspace*{8mm}
    \noindent
    \ifx\@ugLogoPath\empty
      {\large\bfseries\color{ugPrimary}\@ugCompany\par}
    \else
      \raisebox{-4mm}{\includegraphics[height=14mm]{\@ugLogoPath}}%
      \hspace{8pt}{\large\bfseries\color{ugPrimary}\@ugCompany\par}
    \fi

    \vspace{18mm}

    % === TITLE BLOCK (left-aligned) ========================================
    \noindent
    \begin{minipage}[t]{0.55\textwidth}
      % Purple accent bar + App name
      {\color{ugPrimary}\rule{4pt}{38pt}}%
      \hspace{10pt}%
      \raisebox{2pt}{%
        \begin{minipage}[t]{0.85\textwidth}
          {\fontsize{36}{42}\selectfont\bfseries\color{ugPrimary}\@ugAppName\par}
          \ifx\@ugAppSubtitle\empty\else
            \vspace{2mm}
            {\large\color{ugPrimaryLight}\@ugAppSubtitle\par}
          \fi
        \end{minipage}
      }

      \vspace{10mm}

      % USER GUIDE label
      {\fontsize{28}{34}\selectfont\bfseries\color{ugPrimary}USER GUIDE\par}

      \vspace{6mm}

      % Tagline
      \ifx\@ugTagline\empty\else
        {\normalsize\color{ugMutedText}\@ugTagline\par}
      \fi
    \end{minipage}

    \vfill

    % === INFO CARDS =========================================================
    \noindent
    \begin{minipage}[t]{0.55\textwidth}
      \@ugCoverCard{\faTh}{Application Name}{\@ugAppName
        \ifx\@ugAppSubtitle\empty\else\ --- \@ugAppSubtitle\fi}
      \\[10pt]
      \@ugCoverCard{\faPen}{Version}{v\@ugAppVersion}
      \\[10pt]
      \@ugCoverCard{\faFile*[regular]}{Document Version}{\@ugDocVersion}
      \\[10pt]
      \@ugCoverCard{\faCalendar*[regular]}{Release Date}{\@ugReleaseDate}
    \end{minipage}

    \vspace{18mm}

    % === FOOTER =============================================================
    \noindent
    \begin{minipage}[t]{0.45\textwidth}
      \ifx\@ugLogoPath\empty\else
        \raisebox{-3mm}{\includegraphics[height=12mm]{\@ugLogoPath}}%
        \hspace{6pt}
      \fi
      {\normalsize\bfseries\color{ugPrimary}\MakeUppercase{\@ugCompany}\par}
      \ifx\@ugCompanyTagline\empty\else
        \vspace{1mm}
        {\small\color{ugMutedText}\@ugCompanyTagline\par}
      \fi
    \end{minipage}%
    \hfill
    \begin{minipage}[t]{0.48\textwidth}
      \raggedleft\small\color{ugDarkText}
      \ifx\@ugWebsite\empty\else
        {\color{ugPrimary}\faGlobe}\hspace{4pt}\@ugWebsite\\[2pt]
      \fi
      \ifx\@ugEmail\empty\else
        {\color{ugPrimary}\faEnvelope}\hspace{4pt}\@ugEmail\\[2pt]
      \fi
      \ifx\@ugAddress\empty\else
        {\color{ugPrimary}\faMapMarker*}\hspace{4pt}\@ugAddress
      \fi
    \end{minipage}

    \vspace{10mm}
  \end{titlepage}
  \hypersetup{pageanchor=true}%  re-enable page anchors for body
  \setcounter{page}{1}%
}

