}

% Save originals so per-project overrides can fall back for unmatched labels
% (e.g., dynamic-text buttons). The skill writes ui-overrides.tex into the
% same directory as the main .tex; if absent, \ugButton/\ugField/\ugMenu
% retain their default styled-text rendering.
\let\ugButtonOrig\ugButton
\let\ugFieldOrig\ugField
\let\ugMenuOrig\ugMenu

\InputIfFileExists{ui-overrides.tex}{}{}

\endinput
