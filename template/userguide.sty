% ── UI Element Screenshot Overrides — universal scaffold ───────────────────
% Image-rendering helpers used by per-project lookup chains in ui-overrides.tex.
% Buttons/menu items use height-only scaling. Fields cap width so they fit
% inside p{3cm} table cells without overflowing.
\RequirePackage{etoolbox}

\newcommand{\ugElemImg}[1]{%
